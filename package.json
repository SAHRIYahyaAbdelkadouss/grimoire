{
  "name": "grimoire-store",
  "version": "1.2.1",
  "description": "Simple state store with zero dependencies — skips notifying listeners when you set a value that's already the same.",
  "keywords": [
    "state",
    "store",
    "vanilla",
    "reactive",
    "grimoire",
    "lightweight"
  ],
  "homepage": "https://github.com/SAHRIYahyaAbdelkadouss/grimoire#readme",
  "bugs": {
    "url": "https://github.com/SAHRIYahyaAbdelkadouss/grimoire/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SAHRIYahyaAbdelkadouss/grimoire.git"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "ISC",
  "author": "SAHRI Yahya Abdelkadouss",
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "vitest run --coverage",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
