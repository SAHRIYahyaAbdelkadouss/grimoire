#!/usr/bin/env sh

# Capture push refs from stdin first (git passes them via stdin to pre-push)
PUSHING_TAG=""
PUSH_INPUT=$(cat)
echo "$PUSH_INPUT" | while IFS=' ' read -r _local_ref _local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/tags/v*) touch /tmp/.grimoire-tag-push ;;
  esac
done
[ -f /tmp/.grimoire-tag-push ] && PUSHING_TAG="yes" && rm -f /tmp/.grimoire-tag-push

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-push — running full CI pipeline locally"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

echo ""
echo "[ 1/5 ] Validating branch name..."
node scripts/validate-branch.mjs
echo "        ✔ branch name is valid"

echo ""
echo "[ 2/5 ] Running ESLint..."
npm run lint
echo "        ✔ lint passed"

echo ""
echo "[ 3/5 ] Checking code formatting (Prettier)..."
npm run format:check
echo "        ✔ formatting is clean"

echo ""
echo "[ 4/5 ] Building project (tsup)..."
npm run build
echo "        ✔ build succeeded"

echo ""
echo "[ 5/5 ] Running tests + coverage..."
npm test
echo "        ✔ all tests passed — coverage thresholds met"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ✔ all checks passed — push is clear"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# If pushing a version tag, back-merge main → develop after push completes
if [ "$PUSHING_TAG" = "yes" ]; then
  CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
  echo "  ℹ  Tag push detected — will back-merge main → develop after push"
  ( sleep 3 \
    && git switch develop \
    && git pull origin develop \
    && git merge main --no-edit \
    && git push origin develop \
    && git switch "$CURRENT_BRANCH" \
    && echo "  ✔  Back-merge to develop complete" \
    || echo "  ⚠  Back-merge failed — merge main into develop manually" ) &
fi
