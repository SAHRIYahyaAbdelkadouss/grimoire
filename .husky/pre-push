#!/usr/bin/env sh

# Capture push refs from stdin to detect tag pushes
PUSHING_TAG=""
while IFS=' ' read -r _local_ref _local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/tags/v*) PUSHING_TAG="yes" ;;
  esac
done

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-push — running full CI pipeline locally"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

echo ""
echo "[ 1/5 ] Validating branch name..."
node scripts/validate-branch.mjs
echo "        ✔ branch name is valid"

echo ""
echo "[ 2/5 ] Running ESLint..."
npm run lint
echo "        ✔ lint passed"

echo ""
echo "[ 3/5 ] Checking code formatting (Prettier)..."
npm run format:check
echo "        ✔ formatting is clean"

echo ""
echo "[ 4/5 ] Building project (tsup)..."
npm run build
echo "        ✔ build succeeded"

echo ""
echo "[ 5/5 ] Running tests + coverage..."
npm test
echo "        ✔ all tests passed — coverage thresholds met"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ✔ all checks passed — push is clear"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# If pushing a version tag, cherry-pick the version bump to develop
if [ "$PUSHING_TAG" = "yes" ]; then
  CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
  VERSION_COMMIT=$(git rev-parse HEAD)
  echo "  ℹ  Tag push detected — cherry-picking version bump to develop"
  ( sleep 3 \
    && git switch develop \
    && git pull origin develop \
    && git cherry-pick "$VERSION_COMMIT" --no-verify \
    && git push origin develop --no-verify \
    && git switch "$CURRENT_BRANCH" \
    && echo "  ✔  Cherry-pick to develop complete" \
    || { echo "  ⚠  Cherry-pick failed — run manually:"; \
         echo "      git switch develop && git cherry-pick $VERSION_COMMIT"; \
         git cherry-pick --abort 2>/dev/null; \
         git switch "$CURRENT_BRANCH" 2>/dev/null; } ) &
fi
