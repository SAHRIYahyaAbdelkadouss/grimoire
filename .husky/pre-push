#!/usr/bin/env sh

# Capture push refs from stdin to detect tag pushes
PUSHING_TAG=""
while IFS=' ' read -r _local_ref _local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/tags/v*) PUSHING_TAG="yes" ;;
  esac
done

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-push — running full CI pipeline locally"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

echo ""
echo "[ 1/5 ] Validating branch name..."
node scripts/validate-branch.mjs
echo "        ✔ branch name is valid"

echo ""
echo "[ 2/5 ] Running ESLint..."
npm run lint
echo "        ✔ lint passed"

echo ""
echo "[ 3/5 ] Checking code formatting (Prettier)..."
npm run format:check
echo "        ✔ formatting is clean"

echo ""
echo "[ 4/5 ] Building project (tsup)..."
npm run build
echo "        ✔ build succeeded"

echo ""
echo "[ 5/5 ] Running tests + coverage..."
npm test
echo "        ✔ all tests passed — coverage thresholds met"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ✔ all checks passed — push is clear"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# If pushing a version tag, schedule back-merge PR after push completes
if [ "$PUSHING_TAG" = "yes" ]; then
  echo "  ℹ  Tag push detected — back-merge PR will open shortly"
  ( sleep 5 && gh pr create --base develop --head main \
      --title "chore : back-merge after $(git describe --tags --abbrev=0)" \
      --body "Automated back-merge. See **Files changed** tab." \
      2>/dev/null || echo "  ⚠  Back-merge PR skipped (already exists or branches in sync)" ) &
fi
